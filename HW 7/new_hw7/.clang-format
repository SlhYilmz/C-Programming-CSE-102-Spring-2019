# .clang-format for Safety-Critical Aerospace (DO-178C / MISRA)
BasedOnStyle: Microsoft

# --- Reviewability and Auditability ---
# DO-178C requires code to be reviewable. Fixed limits prevent "hidden" code.
ColumnLimit: 0
UseTab: Never
IndentWidth: 4
# Identifiable blocks for MISRA switch-case requirements
IndentCaseLabels: true

# --- Deterministic Formatting ---
# BinPacking: Never/AlwaysOnePerLine ensures each parameter is on its own line.
# This makes it easy to see which specific argument changed in a git diff.
BinPackParameters: false
BinPackArguments: false
AlignAfterOpenBracket: AlwaysBreak

# --- Structural Clarity ---
# Allman style provides the clearest visual scope delimitation.
BreakBeforeBraces: Allman
AllowShortBlocksOnASingleLine: Never
AllowShortFunctionsOnASingleLine: None
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false

# --- Minimizing Diff Noise ---
# We disable consecutive alignment to prevent "cascading" changes in Git 
# when a single variable name or macro value is modified.
AlignConsecutiveAssignments: false
AlignConsecutiveBitFields: true
AlignConsecutiveDeclarations: true
AlignConsecutiveMacros: true

# --- Language Idioms ---
# Right alignment is standard for C-centric safety environments.
PointerAlignment: Left
ReferenceAlignment: Right

# --- Hardware/BSP Safety ---
# In embedded systems/ARINC, include order often matters for 
# hardware abstraction layers and register definitions.
SortIncludes: false

# Formatting for braced lists (struct initializers)
Cpp11BracedListStyle: false